# Security Proxy Configuration
ENVIRONMENT=development
DEBUG=true

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# JWT/Auth
JWT_SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Auth0/Okta Configuration
AUTH0_DOMAIN=dev-auth0.auth0.com
AUTH0_CLIENT_ID=dev-client-id
AUTH0_CLIENT_SECRET=dev-client-secret
AUTH0_API_IDENTIFIER=https://dev-api-identifier

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nelusus_db

# Salesforce Configuration
SALESFORCE_CLIENT_ID=dev-salesforce-client-id
SALESFORCE_CLIENT_SECRET=dev-salesforce-client-secret
SALESFORCE_INSTANCE_URL=https://dev-instance.salesforce.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
